{
  "name": "yoursound",
  "version": "1.0.0",
  "description": "YourSound Streaming Platform",
  "scripts": {
    "install:all": "npm install && npm --prefix frontend install && npm --prefix backend install",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "dev": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "npm --prefix frontend run dev",
    "start:backend": "npm --prefix backend run dev",
    "build": "npm --prefix frontend install && npm --prefix frontend run build && npm --prefix backend install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "socket.io": "^4.8.1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "patch-package": "^8.0.1"
  }
}
